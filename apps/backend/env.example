# Firebase (Cloud Run uses ADC automatically, only set for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Firebase
# Only populate this for local development to point to the Auth Emulator
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Server
PORT=3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=jssi_pos
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Auto-seed the database with sample data on startup (only for local development)
AUTO_SEED=true
NODE_ENV=development